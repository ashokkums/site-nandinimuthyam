# Cloudflare Pages _headers
# Gzip/Brotli is automatic — these headers set caching & security

# HTML — revalidate on every visit
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

# Subdirectory HTML (e.g. dance/index.html)
/**/*.html
  Cache-Control: public, max-age=0, must-revalidate
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

# Subdirectory index pages (e.g. /dance/)
/*/
  Cache-Control: public, max-age=0, must-revalidate
  Expires: 0

# Root
/
  Cache-Control: public, max-age=0, must-revalidate
  Expires: 0

# CSS & JS — long cache (filename-versioned via .min)
/style.min.css
  Cache-Control: public, max-age=31536000, immutable
  Expires: Thu, 31 Dec 2026 23:59:59 GMT
/site.min.js
  Cache-Control: public, max-age=31536000, immutable
  Expires: Thu, 31 Dec 2026 23:59:59 GMT

# Images — cache for 1 year (all depths)
/images/*
  Cache-Control: public, max-age=31536000, immutable
  Expires: Thu, 31 Dec 2026 23:59:59 GMT
/images/**
  Cache-Control: public, max-age=31536000, immutable
  Expires: Thu, 31 Dec 2026 23:59:59 GMT

# Fonts served by Google — already cached by browser
